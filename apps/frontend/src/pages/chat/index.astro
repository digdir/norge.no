---
import { PageLayout } from '@packages/ui/layouts';
import RootLayout from '../../layouts/RootLayout.astro';
import { ChatPage } from '@packages/ui/pages/chat-page';
import { env } from 'cloudflare:workers';

const { ASSISTANT_API_URL }  = env || {};

---
<RootLayout>
  <PageLayout>
    <ChatPage assistantApiUrl={ASSISTANT_API_URL} client:load/>
  </PageLayout>
</RootLayout>

<style>
  :global(body) {
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
  }
  
  :global(main) {
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
</style>
