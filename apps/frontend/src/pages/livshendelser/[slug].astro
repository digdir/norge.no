---
import { PageLayout } from '@packages/ui/layouts';
import { Livshendelse } from '@packages/ui/pages';
import RootLayout from '../../layouts/RootLayout.astro';
import { QueryProvider } from '@packages/data-access/react-query/provider';

const { slug } = Astro.params;
---
<RootLayout>
    <PageLayout>
        {slug &&
            <QueryProvider>
                <Livshendelse slug={slug} client:load/>
            </QueryProvider>
        }
    </PageLayout>
</RootLayout>
