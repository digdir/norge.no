# Gemini
GOOGLE_API_KEY=your_google_api_key_here
FRONTEND_HOST=http://localhost:8085

# Ollama local environment
USE_OLLAMA=true
OLLAMA_MODEL=mistral-nemo
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# Azure OpenAI (Enterprise Configuration)
# Requires an Enterprise SLA with Microsoft for "Zero Data Retention" & GDPR EU boundaries
USE_AZURE_OPENAI=false
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-custom-domain.openai.azure.com/
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
