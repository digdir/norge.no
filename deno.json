{
  "workspace": ["packages/*", "apps/frontend", "apps/assistant"],
  "tasks": {
    "frontend:dev": "cd apps/frontend && sh -c 'wrangler types && astro dev'",
    "frontend:build": "cd apps/frontend && sh -c 'wrangler types && astro build'",
    "frontend:preview": "cd apps/frontend && sh -c 'wrangler types && wrangler dev --ip 0.0.0.0'",
    "assistant:install": "cd apps/assistant && sh -c 'poetry install'",
    "assistant:dev": "cd apps/assistant && sh -c 'poetry run python -m src.main'",
    "assistant:build": "cd apps/assistant && sh -c 'poetry build'"
  },
  "imports": {
    "@astrojs/cloudflare": "npm:@astrojs/cloudflare@^13.1.2",
    "@astrojs/react": "npm:@astrojs/react@^5.0.1",
    "@astrojs/ts-plugin": "npm:@astrojs/ts-plugin@^1.10.7",
    "@digdir/designsystemet-css": "npm:@digdir/designsystemet-css@^1.13.0",
    "@digdir/designsystemet-react": "npm:@digdir/designsystemet-react@^1.13.0",
    "@digdir/designsystemet-theme": "npm:@digdir/designsystemet-theme@^1.11.0",
    "@nanostores/react": "npm:@nanostores/react@^1.1.0",
    "@navikt/aksel-icons": "npm:@navikt/aksel-icons@^8.7.0",
    "@tanstack/react-query": "npm:@tanstack/react-query@^5.91.2",
    "@types/react": "npm:@types/react@^19.2.14",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "classnames": "npm:classnames@^2.5.1",
    "nanostores": "npm:nanostores@^1.2.0",
    "posthog-js": "npm:posthog-js@1.363.0",
    "react": "npm:react@^19.2.4",
    "react-dom": "npm:react-dom@^19.2.4",
    "wrangler": "npm:wrangler@^4.76.0",
    "astro": "npm:astro@^6.0.7"
  },
  "nodeModulesDir": "auto",
  "license": "./LICENSE",
  "compilerOptions": {
    "types": [
      "@digdir/designsystemet-theme",
      "@digdir/designsystemet-react/react-types",
      "./packages/ui/types/css.d.ts"
    ]
  }
}
